datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

enum Role {
  SUPER_ADMIN
  CUSTOMER_ADMIN
  USER
}

enum Action {
  MANAGE
  CREATE
  READ
  EDIT
  DELETE
  EXPORT
  IMPORT
  ASSIGN
  CHANGE_STATUS
}

enum Subject {
  SETTINGS
  USERS
  ROLES
  DASHBOARD_ACCESS
  LOG
  REPORTS
  QUIZZES
}

enum QuizStatus {
  Draft
  Published
  Archived
}

enum QuestionStatus {
  Draft
  Published
  Archived
}

enum QuestionType {
  MCQ
  SHORT_TEXT
  NUMERIC
  SEQUENCE
  ESSAY
}

enum AttemptStatus {
  In_Progress
  Submitted
  Timed_Out
}

model Permission {
  id              String         @id @default(uuid()) @db.Uuid
  action          Action
  subject         Subject
  conditions      Json?
  
  userId          String?        @db.Uuid
  user            User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  permissionSetId String?        @db.Uuid
  permissionSet   PermissionSet? @relation(fields: [permissionSetId], references: [id], onDelete: Cascade)
}

model User {
  id                 String    @id @default(uuid()) @db.Uuid
  email              String    @unique
  passwordHash       String
  role               Role      @default(USER)
  isTwoFactorEnabled Boolean   @default(false)
  twoFactorSecret    String?
  
  workspaceId        String    @db.Uuid
  workspace          Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  permissions        Permission[] 
  
  customRoleId       String?   @db.Uuid
  customRole         CustomRole? @relation(fields: [customRoleId], references: [id], onDelete: SetNull)
  
  reviewsPerformed   AccessReview[] @relation("ReviewerUser")
  
  name               String?
  firstName          String?
  lastName           String?
  company            String?
  phoneNumber        String?
  address            String?
  team               String?
  status             String    @default("Active")
  
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  invitedById        String?   @db.Uuid
  invitedBy          User?     @relation("UserHierarchy", fields: [invitedById], references: [id], onDelete: SetNull)
  invitedUsers       User[]    @relation("UserHierarchy")
  canViewOthers      Boolean   @default(false)
  canManagePermissions Boolean @default(false)

  quizzesCreated     Quiz[]    @relation("QuizCreator")
  questionsCreated   Question[] @relation("QuestionCreator")
  quizAttempts       QuizAttempt[] @relation("StudentAttempts")

  @@index([workspaceId])
}

model Workspace {
  id                 String        @id @default(uuid()) @db.Uuid
  name               String
  
  parentId           String?       @db.Uuid
  parent             Workspace?    @relation("WorkspaceHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  subWorkspaces      Workspace[]   @relation("WorkspaceHierarchy")

  isActive           Boolean       @default(true) 

  users              User[]
  
  customRoles        CustomRole[]
  permissionSets     PermissionSet[]
  accessReviews      AccessReview[]
  
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}

model CustomRole {
  id             String         @id @default(uuid()) @db.Uuid
  name           String
  accessLevel    String
  description    String?
  
  workspaceId    String         @db.Uuid
  workspace      Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  permissionSets PermissionSet[] 
  
  users          User[]         
  
  lastReview     DateTime?
  owner          String         @default("System")
  status         String         @default("Active")
  isSystem       Boolean        @default(false)
  
  accessReviews  AccessReview[]

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([workspaceId, name])
}

model PermissionSet {
  id             String       @id @default(uuid()) @db.Uuid
  name           String
  description    String?

  workspaceId    String       @db.Uuid
  workspace      Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  roles          CustomRole[]   

  permissions    Permission[]   

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([workspaceId, name])
}

model AccessReview {
  id           String      @id @default(uuid()) @db.Uuid
  workspaceId  String      @db.Uuid
  workspace    Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  roleId       String      @db.Uuid
  role         CustomRole  @relation(fields: [roleId], references: [id], onDelete: Cascade)

  reviewerId   String      @db.Uuid
  reviewer     User        @relation("ReviewerUser", fields: [reviewerId], references: [id])

  status       String
  notes        String?

  reviewedAt   DateTime    @default(now())
}

model Course {
  id        String    @id @default(uuid()) @db.Uuid
  title     String    @db.VarChar(255)
  createdAt DateTime  @default(now()) @map("created_at")
  quizzes   Quiz[]

  @@map("courses")
}

model Quiz {
  id                     String         @id @default(uuid()) @db.Uuid
  courseId               String         @map("course_id") @db.Uuid
  course                 Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title                  Json
  description            Json?
  coverImageUrl          String?        @map("cover_image_url")
  durationMinutes        Int            @map("duration_minutes")
  passingScorePercentage Int            @default(70) @map("passing_score_percentage")
  shuffleQuestions       Boolean        @default(false) @map("shuffle_questions")
  status                 QuizStatus     @default(Draft)
  createdById            String         @map("created_by") @db.Uuid
  createdBy              User           @relation("QuizCreator", fields: [createdById], references: [id])
  createdAt              DateTime       @default(now()) @map("created_at")
  updatedAt              DateTime       @updatedAt @map("updated_at")
  quizQuestions          QuizQuestion[]
  attempts               QuizAttempt[]

  @@index([courseId])
  @@index([createdById])
  @@map("quizzes")
}

model Question {
  id           String         @id @default(uuid()) @db.Uuid
  questionText Json           @map("question_text")
  type         QuestionType   @default(MCQ)
  points       Int            @default(1)
  status       QuestionStatus @default(Draft)
  imageUrl     String?        @map("image_url")
  config       Json?
  createdById  String?        @map("created_by") @db.Uuid
  createdBy    User?          @relation("QuestionCreator", fields: [createdById], references: [id])
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  choices      AnswerChoice[]
  quizLinks    QuizQuestion[]
  responses    StudentResponse[]

  @@index([createdById])
  @@index([status])
  @@map("questions")
}

model QuizQuestion {
  id         String   @id @default(uuid()) @db.Uuid
  quizId     String   @map("quiz_id") @db.Uuid
  quiz       Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  questionId String   @map("question_id") @db.Uuid
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  sortOrder  Int      @map("sort_order")

  @@unique([quizId, questionId])
  @@index([quizId])
  @@index([questionId])
  @@map("quiz_questions")
}

model AnswerChoice {
  id         String   @id @default(uuid()) @db.Uuid
  questionId String   @map("question_id") @db.Uuid
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  choiceText Json     @map("choice_text")
  isCorrect  Boolean  @default(false) @map("is_correct")
  responses  StudentResponse[]

  @@index([questionId])
  @@map("answer_choices")
}

model GuestLead {
  id                String        @id @default(uuid()) @db.Uuid
  guestSessionId    String        @unique @map("guest_session_id")
  studentName       String        @map("student_name") @db.VarChar(255)
  school            String        @db.VarChar(255)
  mobileNumber      String        @map("mobile_number") @db.VarChar(20)
  email             String?       @db.VarChar(255)
  quizAttemptsCount Int           @default(0) @map("quiz_attempts_count")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  attempts          QuizAttempt[]

  @@index([mobileNumber])
  @@map("guest_leads")
}

model QuizAttempt {
  id               String        @id @default(uuid()) @db.Uuid
  quizId           String        @map("quiz_id") @db.Uuid
  quiz             Quiz          @relation(fields: [quizId], references: [id], onDelete: Cascade)
  studentId        String?       @map("student_id") @db.Uuid
  student          User?         @relation("StudentAttempts", fields: [studentId], references: [id])
  guestLeadId      String?       @map("guest_lead_id") @db.Uuid
  guestLead        GuestLead?    @relation(fields: [guestLeadId], references: [id], onDelete: Cascade)
  resultToken      String?       @unique @map("result_token")
  startedAt        DateTime      @default(now()) @map("started_at")
  expiresAt        DateTime      @map("expires_at")
  submittedAt      DateTime?     @map("submitted_at")
  lastActivityAt   DateTime      @default(now()) @map("last_activity_at")
  secondsRemaining Int           @map("seconds_remaining")
  violationCount   Int           @default(0) @map("violation_count")
  lastHeartbeatAt  DateTime      @default(now()) @map("last_heartbeat_at")
  questionOrder    Json?         @map("question_order")
  status           AttemptStatus @default(In_Progress)
  finalScore       Int           @default(0) @map("final_score")
  isPassed         Boolean       @default(false) @map("is_passed")
  responses        StudentResponse[]

  @@index([quizId])
  @@index([studentId])
  @@index([guestLeadId])
  @@map("quiz_attempts")
}

model StudentResponse {
  id                String       @id @default(uuid()) @db.Uuid
  attemptId         String       @map("attempt_id") @db.Uuid
  attempt           QuizAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId        String       @map("question_id") @db.Uuid
  question          Question     @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedChoiceId  String?      @map("selected_choice_id") @db.Uuid
  selectedChoice    AnswerChoice? @relation(fields: [selectedChoiceId], references: [id])
  textResponse      String?      @map("text_response")
  timeSpentSeconds  Int          @default(0) @map("time_spent_seconds")
  isCorrect         Boolean      @default(false) @map("is_correct")
  needsManualReview Boolean      @default(false) @map("needs_manual_review")

  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@index([questionId])
  @@map("student_responses")
}