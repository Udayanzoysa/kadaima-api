datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

enum Role {
  SUPER_ADMIN
  CUSTOMER_ADMIN
  USER
}

enum Action {
  MANAGE
  CREATE
  READ
  EDIT
  DELETE
  EXPORT
  IMPORT
  ASSIGN
  CHANGE_STATUS
}

enum Subject {
  SETTINGS
  USERS
  ROLES
  DASHBOARD_ACCESS
  LOG
  REPORTS
  QUIZZES
}

enum QuizStatus {
  Draft
  Published
  Archived
}

enum TeacherQuizVisibility {
  ALL
  SELECTED
}

/// Admin review before a teacher can publish their public page.
enum TeacherReviewStatus {
  Pending
  Active
  Rejected
}

enum TeacherPosterPlacement {
  TOP
  MIDDLE
  FOOTER
  SIDE
  RIGHT
}

enum TeacherInquiryStatus {
  NEW
  READ
  ARCHIVED
}

enum QuestionStatus {
  Draft
  Published
  Archived
}

enum CourseStatus {
  Draft
  Published
  Archived
}

enum QuestionType {
  MCQ
  SHORT_TEXT
  NUMERIC
  SEQUENCE
  ESSAY
}

enum AttemptStatus {
  In_Progress
  Submitted
  Timed_Out
}

enum PaymentOrderStatus {
  Pending
  Paid
  Failed
  Cancelled
}

enum PaymentProvider {
  PayHere
}

enum UnlockMethod {
  PayHere
  Voucher
  Slip
}

enum SlipSubmissionStatus {
  Pending
  Approved
  Rejected
}

enum PasswordResetChannel {
  EMAIL
  SMS
}

model Permission {
  id              String         @id @default(uuid()) @db.Uuid
  action          Action
  subject         Subject
  conditions      Json?
  
  userId          String?        @db.Uuid
  user            User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  permissionSetId String?        @db.Uuid
  permissionSet   PermissionSet? @relation(fields: [permissionSetId], references: [id], onDelete: Cascade)
}

model User {
  id                 String    @id @default(uuid()) @db.Uuid
  email              String    @unique
  /// Null for Google-only accounts (no local password).
  passwordHash       String?
  /// Google subject (`sub`) when signed in with Google.
  googleId           String?   @unique
  role               Role      @default(USER)
  isTwoFactorEnabled Boolean   @default(false)
  twoFactorSecret    String?
  
  workspaceId        String    @db.Uuid
  workspace          Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  permissions        Permission[] 
  
  customRoleId       String?   @db.Uuid
  customRole         CustomRole? @relation(fields: [customRoleId], references: [id], onDelete: SetNull)
  
  reviewsPerformed   AccessReview[] @relation("ReviewerUser")
  
  name               String?
  firstName          String?
  lastName           String?
  company            String?
  phoneNumber        String?
  address            String?
  team               String?
  status             String    @default("Active")
  
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  invitedById        String?   @db.Uuid
  invitedBy          User?     @relation("UserHierarchy", fields: [invitedById], references: [id], onDelete: SetNull)
  invitedUsers       User[]    @relation("UserHierarchy")
  canViewOthers      Boolean   @default(false)
  canManagePermissions Boolean @default(false)

  quizzesCreated     Quiz[]    @relation("QuizCreator")
  questionsCreated   Question[] @relation("QuestionCreator")
  quizAttempts       QuizAttempt[] @relation("StudentAttempts")
  paymentOrders      PaymentOrder[]
  quizUnlocks        QuizUnlock[]
  slipSubmissions    PaymentSlipSubmission[]
  passwordResetTokens PasswordResetToken[]
  teacherProfile     TeacherProfile?

  @@index([workspaceId])
  @@index([workspaceId, status])
  @@index([status])
  @@index([team])
  @@index([customRoleId])
  @@index([createdAt])
  @@index([invitedById])
}

/// Public branded landing for a teacher (shared DB, user-scoped — not a new workspace).
model TeacherProfile {
  id             String                 @id @default(uuid()) @db.Uuid
  userId         String                 @unique @map("user_id") @db.Uuid
  user           User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  slug           String                 @unique @db.VarChar(64)
  displayName    String                 @map("display_name") @db.VarChar(255)
  title          String?                @db.VarChar(255)
  description    String?                @db.Text
  /// Editable About section body on /t/{slug}
  aboutText      String?                @map("about_text") @db.Text
  /// Editable Contact section body on /t/{slug}
  contactText    String?                @map("contact_text") @db.Text
  contactPhone   String?                @map("contact_phone") @db.VarChar(64)
  contactWhatsappUrl String?            @map("contact_whatsapp_url") @db.VarChar(512)
  contactAddress String?                @map("contact_address") @db.Text
  sideBannerUrl  String?                @map("side_banner_url")
  isPublic       Boolean                @default(false) @map("is_public")
  /// Pending until an admin activates the teacher on the Users page.
  reviewStatus   TeacherReviewStatus    @default(Active) @map("review_status")
  quizVisibility TeacherQuizVisibility  @default(ALL) @map("quiz_visibility")
  /// Page-builder layout: section visibility + order for /t/{slug}
  pageLayout     Json?                  @map("page_layout")
  createdAt      DateTime               @default(now()) @map("created_at")
  updatedAt      DateTime               @updatedAt @map("updated_at")
  banners         TeacherBanner[]
  classes         TeacherClass[]
  posters         TeacherPoster[]
  selectedQuizzes TeacherProfileQuiz[]
  inquiries       TeacherContactInquiry[]

  @@index([slug])
  @@index([reviewStatus])
  @@map("teacher_profiles")
}

/// Student inquiries submitted from the public /t/{slug} Contact form.
model TeacherContactInquiry {
  id             String               @id @default(uuid()) @db.Uuid
  profileId      String               @map("profile_id") @db.Uuid
  profile        TeacherProfile       @relation(fields: [profileId], references: [id], onDelete: Cascade)
  guestSessionId String?              @map("guest_session_id") @db.VarChar(64)
  userId         String?              @map("user_id") @db.Uuid
  studentName    String               @map("student_name") @db.VarChar(255)
  mobileNumber   String               @map("mobile_number") @db.VarChar(32)
  email          String?              @db.VarChar(255)
  message        String               @db.Text
  status         TeacherInquiryStatus @default(NEW)
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")

  @@index([profileId, createdAt])
  @@index([profileId, status])
  @@map("teacher_contact_inquiries")
}

/// Quizzes explicitly featured on a teacher public page when quizVisibility = SELECTED.
model TeacherProfileQuiz {
  id        String         @id @default(uuid()) @db.Uuid
  profileId String         @map("profile_id") @db.Uuid
  profile   TeacherProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  quizId    String         @map("quiz_id") @db.Uuid
  quiz      Quiz           @relation(fields: [quizId], references: [id], onDelete: Cascade)
  createdAt DateTime       @default(now()) @map("created_at")

  @@unique([profileId, quizId])
  @@index([profileId])
  @@index([quizId])
  @@map("teacher_profile_quizzes")
}

model TeacherBanner {
  id        String         @id @default(uuid()) @db.Uuid
  profileId String         @map("profile_id") @db.Uuid
  profile   TeacherProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  imageUrl  String         @map("image_url")
  linkUrl   String?        @map("link_url")
  title     String?        @db.VarChar(255)
  subtitle  String?        @db.Text
  ctaLabel  String?        @map("cta_label") @db.VarChar(80)
  sortOrder Int            @default(0) @map("sort_order")
  isActive  Boolean        @default(true) @map("is_active")
  createdAt DateTime       @default(now()) @map("created_at")

  @@index([profileId])
  @@map("teacher_banners")
}

model TeacherClass {
  id           String         @id @default(uuid()) @db.Uuid
  profileId    String         @map("profile_id") @db.Uuid
  profile      TeacherProfile @relation(fields: [profileId], references: [id], onDelete: Cascade)
  title        String         @db.VarChar(255)
  description  String?        @db.Text
  scheduleTime String?        @map("schedule_time") @db.VarChar(120)
  location     String?        @db.VarChar(255)
  classDate    String?        @map("class_date") @db.VarChar(120)
  feeLabel          String?        @map("fee_label") @db.VarChar(80)
  whatsappGroupUrl  String?        @map("whatsapp_group_url") @db.VarChar(500)
  sortOrder         Int            @default(0) @map("sort_order")
  isActive          Boolean        @default(true) @map("is_active")
  createdAt         DateTime       @default(now()) @map("created_at")

  @@index([profileId])
  @@map("teacher_classes")
}

/// Static poster / promo banners placed at top, middle, or footer of /t/{slug}
model TeacherPoster {
  id        String                 @id @default(uuid()) @db.Uuid
  profileId String                 @map("profile_id") @db.Uuid
  profile   TeacherProfile         @relation(fields: [profileId], references: [id], onDelete: Cascade)
  imageUrl  String                 @map("image_url")
  linkUrl   String?                @map("link_url")
  title     String?                @db.VarChar(255)
  placement TeacherPosterPlacement @default(MIDDLE)
  sortOrder Int                    @default(0) @map("sort_order")
  isActive  Boolean                @default(true) @map("is_active")
  createdAt DateTime               @default(now()) @map("created_at")

  @@index([profileId])
  @@map("teacher_posters")
}

model PasswordResetToken {
  id          String                @id @default(uuid()) @db.Uuid
  token       String                @unique
  userId      String                @map("user_id") @db.Uuid
  user        User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel     PasswordResetChannel
  destination String                @db.VarChar(255)
  expiresAt   DateTime              @map("expires_at")
  isUsed      Boolean               @default(false) @map("is_used")
  createdAt   DateTime              @default(now()) @map("created_at")

  @@index([userId])
  @@index([token])
  @@map("password_reset_tokens")
}

// Platform-wide notification transport settings (SMTP + SMS). Singleton row id = "default".
model SystemSetting {
  id        String   @id @default("default")
  smtp      Json?
  sms       Json?
  updatedAt DateTime @updatedAt @map("updated_at")
  updatedBy String?  @map("updated_by")

  @@map("system_settings")
}

model Workspace {
  id                 String        @id @default(uuid()) @db.Uuid
  name               String
  
  parentId           String?       @db.Uuid
  parent             Workspace?    @relation("WorkspaceHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  subWorkspaces      Workspace[]   @relation("WorkspaceHierarchy")

  isActive           Boolean       @default(true) 

  users              User[]
  
  customRoles        CustomRole[]
  permissionSets     PermissionSet[]
  accessReviews      AccessReview[]
  
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
}

model CustomRole {
  id             String         @id @default(uuid()) @db.Uuid
  name           String
  accessLevel    String
  description    String?
  
  workspaceId    String         @db.Uuid
  workspace      Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  
  permissionSets PermissionSet[] 
  
  users          User[]         
  
  lastReview     DateTime?
  owner          String         @default("System")
  status         String         @default("Active")
  isSystem       Boolean        @default(false)
  
  accessReviews  AccessReview[]

  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  @@unique([workspaceId, name])
}

model PermissionSet {
  id             String       @id @default(uuid()) @db.Uuid
  name           String
  description    String?

  workspaceId    String       @db.Uuid
  workspace      Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  roles          CustomRole[]   

  permissions    Permission[]   

  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@unique([workspaceId, name])
}

model AccessReview {
  id           String      @id @default(uuid()) @db.Uuid
  workspaceId  String      @db.Uuid
  workspace    Workspace   @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  roleId       String      @db.Uuid
  role         CustomRole  @relation(fields: [roleId], references: [id], onDelete: Cascade)

  reviewerId   String      @db.Uuid
  reviewer     User        @relation("ReviewerUser", fields: [reviewerId], references: [id], onDelete: Cascade)

  status       String
  notes        String?

  reviewedAt   DateTime    @default(now())

  @@index([workspaceId])
  @@index([reviewerId])
}

model Course {
  id          String       @id @default(uuid()) @db.Uuid
  title       Json
  description Json?
  status      CourseStatus @default(Draft)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  quizzes     Quiz[]
  modules     Module[]

  @@map("courses")
}

model Module {
  id          String       @id @default(uuid()) @db.Uuid
  courseId    String       @map("course_id") @db.Uuid
  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  title       Json
  description Json?
  status      CourseStatus @default(Draft)
  sortOrder   Int          @default(0) @map("sort_order")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  quizzes     Quiz[]

  @@index([courseId])
  @@map("modules")
}

model Quiz {
  id                     String         @id @default(uuid()) @db.Uuid
  courseId               String         @map("course_id") @db.Uuid
  course                 Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  moduleId               String?        @map("module_id") @db.Uuid
  module                 Module?        @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  title                  Json
  description            Json?
  coverImageUrl          String?        @map("cover_image_url")
  durationMinutes        Int            @map("duration_minutes")
  passingScorePercentage Int            @default(70) @map("passing_score_percentage")
  maxAttempts            Int            @default(1) @map("max_attempts")
  shuffleQuestions       Boolean        @default(false) @map("shuffle_questions")
  requiresUnlock         Boolean        @default(false) @map("requires_unlock")
  priceLkr               Decimal?       @map("price_lkr") @db.Decimal(12, 2)
  status                 QuizStatus     @default(Draft)
  createdById            String         @map("created_by") @db.Uuid
  createdBy              User           @relation("QuizCreator", fields: [createdById], references: [id], onDelete: Restrict)
  createdAt              DateTime       @default(now()) @map("created_at")
  updatedAt              DateTime       @updatedAt @map("updated_at")
  quizQuestions          QuizQuestion[]
  attempts               QuizAttempt[]
  paymentOrders          PaymentOrder[]
  unlocks                QuizUnlock[]
  unlockVouchers         UnlockVoucher[]
  slipSubmissions        PaymentSlipSubmission[]
  teacherPageSelections  TeacherProfileQuiz[]

  @@index([courseId])
  @@index([moduleId])
  @@index([createdById])
  @@index([status])
  @@map("quizzes")
}

model PaymentOrder {
  id                String             @id @default(uuid()) @db.Uuid
  orderId           String             @unique @map("order_id") @db.VarChar(64)
  quizId            String             @map("quiz_id") @db.Uuid
  quiz              Quiz               @relation(fields: [quizId], references: [id], onDelete: Cascade)
  guestSessionId    String?            @map("guest_session_id") @db.VarChar(64)
  userId            String?            @map("user_id") @db.Uuid
  user              User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  amountLkr         Decimal            @map("amount_lkr") @db.Decimal(12, 2)
  currency          String             @default("LKR") @db.VarChar(3)
  status            PaymentOrderStatus @default(Pending)
  provider          PaymentProvider    @default(PayHere)
  providerPaymentId String?            @map("provider_payment_id") @db.VarChar(64)
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  unlock            QuizUnlock?

  @@index([quizId])
  @@index([guestSessionId])
  @@index([userId])
  @@map("payment_orders")
}

model UnlockVoucher {
  id            String    @id @default(uuid()) @db.Uuid
  code          String    @unique @db.VarChar(64)
  quizId        String?   @map("quiz_id") @db.Uuid
  quiz          Quiz?     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  maxRedemptions Int      @default(1) @map("max_redemptions")
  redemptionCount Int     @default(0) @map("redemption_count")
  expiresAt     DateTime? @map("expires_at")
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  unlocks       QuizUnlock[]

  @@index([quizId])
  @@map("unlock_vouchers")
}

model PaymentSlipSubmission {
  id             String               @id @default(uuid()) @db.Uuid
  quizId         String               @map("quiz_id") @db.Uuid
  quiz           Quiz                 @relation(fields: [quizId], references: [id], onDelete: Cascade)
  guestSessionId String?              @map("guest_session_id") @db.VarChar(64)
  userId         String?              @map("user_id") @db.Uuid
  user           User?                @relation(fields: [userId], references: [id], onDelete: SetNull)
  slipImageUrl   String               @map("slip_image_url")
  bankReference  String?              @map("bank_reference") @db.VarChar(100)
  note           String?
  status         SlipSubmissionStatus @default(Pending)
  reviewedAt     DateTime?            @map("reviewed_at")
  createdAt      DateTime             @default(now()) @map("created_at")
  updatedAt      DateTime             @updatedAt @map("updated_at")
  unlock         QuizUnlock?

  @@index([quizId])
  @@index([guestSessionId])
  @@index([userId])
  @@map("payment_slip_submissions")
}

model QuizUnlock {
  id                String                 @id @default(uuid()) @db.Uuid
  quizId            String                 @map("quiz_id") @db.Uuid
  quiz              Quiz                   @relation(fields: [quizId], references: [id], onDelete: Cascade)
  guestSessionId    String?                @map("guest_session_id") @db.VarChar(64)
  userId            String?                @map("user_id") @db.Uuid
  user              User?                  @relation(fields: [userId], references: [id], onDelete: SetNull)
  method            UnlockMethod
  paymentOrderId    String?                @unique @map("payment_order_id") @db.Uuid
  paymentOrder      PaymentOrder?          @relation(fields: [paymentOrderId], references: [id], onDelete: SetNull)
  voucherCodeId     String?                @map("voucher_code_id") @db.Uuid
  voucher           UnlockVoucher?         @relation(fields: [voucherCodeId], references: [id], onDelete: SetNull)
  slipSubmissionId  String?                @unique @map("slip_submission_id") @db.Uuid
  slipSubmission    PaymentSlipSubmission? @relation(fields: [slipSubmissionId], references: [id], onDelete: SetNull)
  createdAt         DateTime               @default(now()) @map("created_at")

  @@unique([quizId, guestSessionId])
  @@unique([quizId, userId])
  @@index([guestSessionId])
  @@index([userId])
  @@map("quiz_unlocks")
}

model Question {
  id           String         @id @default(uuid()) @db.Uuid
  questionText Json           @map("question_text")
  type         QuestionType   @default(MCQ)
  points       Int            @default(1)
  status       QuestionStatus @default(Draft)
  imageUrl     String?        @map("image_url")
  config       Json?
  createdById  String?        @map("created_by") @db.Uuid
  createdBy    User?          @relation("QuestionCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  choices      AnswerChoice[]
  quizLinks    QuizQuestion[]
  responses    StudentResponse[]

  @@index([createdById])
  @@index([status])
  @@map("questions")
}

model QuizQuestion {
  id         String   @id @default(uuid()) @db.Uuid
  quizId     String   @map("quiz_id") @db.Uuid
  quiz       Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  questionId String   @map("question_id") @db.Uuid
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  sortOrder  Int      @map("sort_order")

  @@unique([quizId, questionId])
  @@index([quizId])
  @@index([questionId])
  @@map("quiz_questions")
}

model AnswerChoice {
  id         String   @id @default(uuid()) @db.Uuid
  questionId String   @map("question_id") @db.Uuid
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  choiceText Json     @map("choice_text")
  isCorrect  Boolean  @default(false) @map("is_correct")
  responses  StudentResponse[]

  @@index([questionId])
  @@map("answer_choices")
}

model GuestLead {
  id                String        @id @default(uuid()) @db.Uuid
  guestSessionId    String        @unique @map("guest_session_id")
  studentName       String        @map("student_name") @db.VarChar(255)
  school            String        @db.VarChar(255)
  mobileNumber      String        @map("mobile_number") @db.VarChar(20)
  email             String?       @db.VarChar(255)
  quizAttemptsCount Int           @default(0) @map("quiz_attempts_count")
  createdAt         DateTime      @default(now()) @map("created_at")
  updatedAt         DateTime      @updatedAt @map("updated_at")
  attempts          QuizAttempt[]

  @@index([mobileNumber])
  @@map("guest_leads")
}

model QuizAttempt {
  id               String        @id @default(uuid()) @db.Uuid
  quizId           String        @map("quiz_id") @db.Uuid
  quiz             Quiz          @relation(fields: [quizId], references: [id], onDelete: Cascade)
  studentId        String?       @map("student_id") @db.Uuid
  student          User?         @relation("StudentAttempts", fields: [studentId], references: [id], onDelete: SetNull)
  guestLeadId      String?       @map("guest_lead_id") @db.Uuid
  guestLead        GuestLead?    @relation(fields: [guestLeadId], references: [id], onDelete: Cascade)
  resultToken      String?       @unique @map("result_token")
  startedAt        DateTime      @default(now()) @map("started_at")
  expiresAt        DateTime      @map("expires_at")
  submittedAt      DateTime?     @map("submitted_at")
  lastActivityAt   DateTime      @default(now()) @map("last_activity_at")
  secondsRemaining Int           @map("seconds_remaining")
  violationCount   Int           @default(0) @map("violation_count")
  lastHeartbeatAt  DateTime      @default(now()) @map("last_heartbeat_at")
  questionOrder    Json?         @map("question_order")
  status           AttemptStatus @default(In_Progress)
  finalScore       Int           @default(0) @map("final_score")
  isPassed         Boolean       @default(false) @map("is_passed")
  responses        StudentResponse[]

  @@index([quizId])
  @@index([studentId])
  @@index([guestLeadId])
  @@map("quiz_attempts")
}

model StudentResponse {
  id                String       @id @default(uuid()) @db.Uuid
  attemptId         String       @map("attempt_id") @db.Uuid
  attempt           QuizAttempt  @relation(fields: [attemptId], references: [id], onDelete: Cascade)
  questionId        String       @map("question_id") @db.Uuid
  question          Question     @relation(fields: [questionId], references: [id], onDelete: Cascade)
  selectedChoiceId  String?      @map("selected_choice_id") @db.Uuid
  selectedChoice    AnswerChoice? @relation(fields: [selectedChoiceId], references: [id])
  textResponse      String?      @map("text_response")
  timeSpentSeconds  Int          @default(0) @map("time_spent_seconds")
  isCorrect         Boolean      @default(false) @map("is_correct")
  needsManualReview Boolean      @default(false) @map("needs_manual_review")

  @@unique([attemptId, questionId])
  @@index([attemptId])
  @@index([questionId])
  @@map("student_responses")
}